# =========================================================================
# Mathematical Dependency Interface - .gitignore
# =========================================================================

# -------------------------------------------------------------------------
# Datasets & Generated Data
# (Ignored due to large file sizes over GitHub's 50MB/100MB limit)
# -------------------------------------------------------------------------
data/generated/*
!data/generated/.gitkeep

public/data/*
!public/data/.gitkeep

# -------------------------------------------------------------------------
# Playwright & Testing Outputs
# -------------------------------------------------------------------------
.playwright-cli/
output/playwright/

# -------------------------------------------------------------------------
# OS / System Files
# -------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# -------------------------------------------------------------------------
# IDEs, Editors & Tools
# -------------------------------------------------------------------------
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*~
.project
.classpath
.settings/
.recommenders/
